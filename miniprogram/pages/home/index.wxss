  padding: 24rpx 32rpx;
  background: #FFF9F5;
  border-bottom: 2rpx solid #F0F0F0;
}

.summary-text {
  font-size: 26rpx;
  color: #FF9A8B;
  font-weight: 300;
  text-align: center;
  display: block;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #5A5A5A;
  font-weight: 300;
  margin-bottom: 20rpx;
}

.options-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.option-item {
  padding: 24rpx 16rpx;
  background: #FFF9F5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #5A5A5A;
  font-weight: 300;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.selected {
  background: #FF9A8B;
  color: white;
  border-color: #FF9A8B;
}

.option-item:active {
  background: #FFE8E3;
  transform: scale(0.98);
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.form-input {
  flex: 1;
  padding: 24rpx 32rpx;
  background: #FFF9F5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #5A5A5A;
  font-weight: 300;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #FF9A8B;
  background: white;
}

.unit-selector {
  display: flex;
  gap: 12rpx;
}

.unit-option {
  padding: 20rpx 32rpx;
  background: #FFF9F5;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #5A5A5A;
  font-weight: 300;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.unit-option.selected {
  background: #FF9A8B;
  color: white;
  border-color: #FF9A8B;
}

.unit-option:active {
  background: #FFE8E3;
  transform: scale(0.98);
}

.modal-footer {
  display: flex;
  padding: 32rpx;
  border-top: 2rpx solid #F0F0F0;
  gap: 24rpx;
}

.btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 300;
  transition: all 0.3s ease;
}

.btn-cancel {
  background: #F0F0F0;
  color: #8A8A8A;
}

.btn-cancel:active {
  background: #E0E0E0;
  transform: scale(0.98);
}

.btn-primary {
  background: #FF9A8B;
  color: white;
}

.btn-primary:active {
  background: #FF8A7A;
  transform: scale(0.98);
}

/* 修复：弹窗右偏与按钮贴边（覆盖重复样式导致的宽度溢出） */
.modal-overlay {
  left: 0 !important;
  right: 0 !important;
  width: 100vw !important;
}

.modal-content {
  width: 100% !important;
  max-width: 100vw !important;
  box-sizing: border-box !important;
}

.record-modal {
  width: 100% !important;
  max-width: 100vw !important;
  box-sizing: border-box !important;
}

.modal-header,
.modal-body,
.modal-summary,
.modal-footer,
.btn {
  box-sizing: border-box !important;
}

.modal-footer {
  width: 100% !important;
  gap: 16rpx !important;
  padding-right: 24rpx !important;
  padding-left: 24rpx !important;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom)) !important;
}

.btn {
  min-width: 0;
}
