/* home/index.wxss */

.home-container {
  width: 750rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF9F5;
}

/* 顶部导航栏 — padding-top由JS动态注入statusBarHeight */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 20rpx;
  padding-right: 20rpx;
  padding-bottom: 8rpx;
  background: #FFF9F5;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-left { flex: 1; }

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5A5A5A;
  letter-spacing: 2rpx;
}

.navbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.navbar-icon {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: rgba(255,154,139,0.1);
  border-radius: 40rpx;
}

.navbar-icon:active { background: rgba(255,154,139,0.2); }
.icon { font-size: 30rpx; }
.pet-name { font-size: 24rpx; color: #5A5A5A; }

/* 主内容滚动区 */
.main-content { flex: 1; }

/* ── 日历区 ─────────────────────────────── */
.date-section {
  padding: 16rpx 24rpx 24rpx;
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cal-month-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5A5A5A;
}

.cal-nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #FFF9F5;
  font-size: 36rpx;
  color: #FF9A8B;
}

.cal-nav-btn:active { background: #FFE8E3; }

/* 星期头部 */
.cal-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 8rpx;
}

.cal-weekday {
  text-align: center;
  font-size: 22rpx;
  color: #8A8A8A;
  padding: 8rpx 0;
}

/* 日历格子 — 正方形 */
.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.cal-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
  transition: background 0.2s;
}

.cal-cell:active { background: #FFE8E3; }

.cal-cell.other .cal-day-num { color: #D0D0D0; }

.cal-cell.today .cal-day-num {
  color: #FF9A8B;
  font-weight: 700;
}

.cal-cell.selected {
  background: #FF9A8B;
  border-radius: 12rpx;
}

.cal-cell.selected .cal-day-num { color: white; font-weight: 700; }

.cal-day-num {
  font-size: 28rpx;
  color: #5A5A5A;
  line-height: 1;
}

.cal-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FF9A8B;
  margin-top: 4rpx;
}

.cal-cell.selected .cal-dot { background: white; }

/* 已选日期提示栏 */
.selected-date-bar {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F0F0F0;
  text-align: center;
}

.selected-date-text {
  font-size: 26rpx;
  color: #FF9A8B;
  font-weight: 500;
}

/* ── AI 摘要与异常提醒 ───────────────────── */
.ai-insights-section {
  padding: 0 24rpx;
  margin-bottom: 18rpx;
}

.ai-summary-card,
.ai-alert-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.ai-summary-card:active {
  transform: scale(0.995);
}

.ai-alert-card {
  margin-top: 14rpx;
  border: 2rpx solid #FFD8D2;
  background: #FFF7F6;
}

.ai-summary-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.ai-badge {
  font-size: 20rpx;
  color: #fff;
  background: #FF9A8B;
  border-radius: 20rpx;
  padding: 2rpx 10rpx;
}

.ai-title {
  font-size: 26rpx;
  color: #5A5A5A;
  font-weight: 600;
}

.ai-source-tag {
  margin-left: auto;
  font-size: 20rpx;
  color: #9A8D88;
  background: #F7F1EE;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.ai-summary-text {
  font-size: 24rpx;
  color: #6A6A6A;
  line-height: 1.7;
}

.ai-quick-focus {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 10rpx;
}

.ai-quick-title {
  font-size: 22rpx;
  color: #9A6E65;
  font-weight: 600;
}

.ai-quick-text {
  flex: 1;
  font-size: 22rpx;
  color: #7A6A66;
  line-height: 1.6;
}

.ai-alert-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.ai-alert-title {
  display: block;
  font-size: 25rpx;
  color: #D95E4B;
  font-weight: 600;
  margin-bottom: 0;
}

.ai-alert-item {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.ai-alert-item:last-child {
  margin-bottom: 0;
}

.ai-alert-dot {
  color: #E16E5D;
  font-size: 24rpx;
  line-height: 1.5;
}

.ai-alert-text {
  flex: 1;
  font-size: 24rpx;
  color: #8A4F46;
  line-height: 1.6;
}

.ai-alert-normal {
  display: block;
  font-size: 24rpx;
  color: #6B9A62;
  line-height: 1.6;
}

.summary-detail-modal {
  width: 88%;
  max-height: 62vh;
  border-radius: 24rpx;
}

.summary-detail-text {
  display: block;
  font-size: 28rpx;
  color: #5A5A5A;
  line-height: 1.8;
}

.insight-block {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #F3ECEA;
}

.insight-title {
  display: block;
  font-size: 24rpx;
  color: #7C6460;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.insight-dot {
  font-size: 22rpx;
  color: #C97F72;
  line-height: 1.6;
}

.insight-text {
  flex: 1;
  font-size: 22rpx;
  color: #6E6160;
  line-height: 1.7;
}

/* ── 记录卡片 ───────────────────────────── */
.records-section { padding: 0 24rpx; }

.module-section {
  margin-bottom: 24rpx;
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.module-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.module-title { font-size: 30rpx; font-weight: 600; color: #5A5A5A; }
.module-subtitle { font-size: 22rpx; color: #8A8A8A; }
.module-divider { height: 2rpx; background: #F5F5F5; margin-bottom: 24rpx; }

.cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.card-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  background: #FFF9F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.card-item:active { background: #FFE8E3; border-color: #FF9A8B; }
.card-icon { font-size: 44rpx; margin-bottom: 12rpx; }
.card-title { font-size: 26rpx; color: #5A5A5A; margin-bottom: 6rpx; }
.card-subtitle { font-size: 20rpx; color: #8A8A8A; text-align: center; }

.bottom-space { height: 120rpx; }

/* ── 弹窗通用 ───────────────────────────── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 750rpx; height: 100vh;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 75vh;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.modal-title { font-size: 32rpx; font-weight: 600; color: #5A5A5A; }

.modal-close {
  font-size: 44rpx;
  color: #8A8A8A;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.modal-close:active { background: #F0F0F0; }
.modal-body { max-height: 55vh; padding: 24rpx 32rpx; }

.modal-summary { padding: 20rpx 32rpx; background: #FFF9F5; border-bottom: 2rpx solid #F0F0F0; }
.summary-text { font-size: 26rpx; color: #FF9A8B; text-align: center; display: block; }

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #F0F0F0;
  gap: 24rpx;
}

.btn { flex: 1; padding: 28rpx; text-align: center; border-radius: 16rpx; font-size: 28rpx; }
.btn-cancel { background: #F0F0F0; color: #8A8A8A; }
.btn-cancel:active { background: #E0E0E0; }
.btn-primary { background: #FF9A8B; color: white; }
.btn-primary:active { background: #FF8A7A; }

/* 表单 */
.form-section { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; color: #5A5A5A; margin-bottom: 16rpx; }
.options-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16rpx; }
.option-item { padding: 22rpx 12rpx; background: #FFF9F5; border-radius: 14rpx; text-align: center; font-size: 26rpx; color: #5A5A5A; border: 2rpx solid transparent; }
.option-item.selected { background: #FF9A8B; color: white; border-color: #FF9A8B; }
.option-item:active { background: #FFE8E3; }
.input-with-unit { display: flex; align-items: center; gap: 16rpx; }
.form-input { flex: 1; padding: 22rpx 28rpx; background: #FFF9F5; border-radius: 14rpx; font-size: 28rpx; color: #5A5A5A; border: 2rpx solid transparent; }
.form-input:focus { border-color: #FF9A8B; background: white; }
.unit-selector { display: flex; gap: 10rpx; }
.unit-option { padding: 18rpx 24rpx; background: #FFF9F5; border-radius: 14rpx; font-size: 26rpx; color: #5A5A5A; border: 2rpx solid transparent; }
.unit-option.selected { background: #FF9A8B; color: white; border-color: #FF9A8B; }

/* 宠物选择弹窗 */
.pet-item { display: flex; align-items: center; padding: 22rpx; border-radius: 18rpx; margin-bottom: 14rpx; border: 2rpx solid transparent; }
.pet-item.selected { background: #2F2F2F; border-color: #2F2F2F; }
.pet-item.selected .pet-name,
.pet-item.selected .pet-details,
.pet-item.selected .pet-check { color: #fff; }
.pet-item:active { background: #F0F0F0; }
.pet-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #FF9A8B; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.pet-avatar-text { font-size: 32rpx; }
.pet-info { flex: 1; }
.pet-name { font-size: 28rpx; color: #5A5A5A; display: block; margin-bottom: 4rpx; }
.pet-details { font-size: 22rpx; color: #8A8A8A; }
.pet-check { font-size: 32rpx; color: #FF9A8B; font-weight: bold; }
.add-pet-btn { display: flex; align-items: center; justify-content: center; padding: 28rpx; border: 2rpx dashed #E0E0E0; border-radius: 18rpx; margin-top: 14rpx; }
.add-pet-btn:active { border-color: #FF9A8B; background: #FFF9F5; }
.add-icon { font-size: 32rpx; color: #FF9A8B; margin-right: 12rpx; }
.add-text { font-size: 28rpx; color: #5A5A5A; }

/* 记录弹窗尺寸 */
