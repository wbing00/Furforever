/* splash/index.wxss */

.splash-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* 背景渐变 */
.background-gradient {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FFF9F5 0%, #FFE8E3 50%, #FFD6CE 100%);
  z-index: -1;
}

/* 主要内容 */
.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 40rpx;
}



/* 爪印图片样式：增加点击反馈 */
.logo-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  object-fit: contain;
  transition: all 0.2s ease; /* 动画过渡 */
  cursor: pointer; /* 鼠标悬浮指针（开发者工具适配） */
}
/* 点击时缩放，模拟按压效果 */
.logo-img:active {
  transform: scale(0.92);
}

/* 新增：爪印呼吸动画（仅加载完成后显示，配合data-isLoading） */
.content:not(:has(.loading-text)) .logo-img {
  animation: breath 2s infinite ease-in-out;
}
/* 呼吸动画关键帧 */
@keyframes breath {
  0%,100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.paw-pad {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: #FF9A8B;
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(255, 154, 139, 0.3);
}

.paw-toe {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background: #FF9A8B;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 139, 0.3);
}

.toe-1 {
  top: 20rpx;
  left: 70rpx;
}

.toe-2 {
  top: 20rpx;
  right: 70rpx;
}

.toe-3 {
  top: 70rpx;
  left: 20rpx;
}

.toe-4 {
  top: 70rpx;
  right: 20rpx;
}

/* 应用名称 */
.app-name {
  font-size: 48rpx;
  font-weight: 300;
  color: #5A5A5A;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #8A8A8A;
  margin-bottom: 80rpx;
  font-weight: 300;
}

/* 加载提示 */
.loading-text {
  font-size: 28rpx;
  color: #8A8A8A;
  margin-top: 40rpx;
  animation: fadeInOut 1.5s infinite;
}

@keyframes fadeInOut {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 进入按钮 */
.enter-btn {
  margin-top: 40rpx;
  padding: 24rpx 64rpx;
  background: #FF9A8B;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 139, 0.3);
  transition: all 0.3s ease;
}

.enter-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 139, 0.3);
}

/* 底部版权信息 */
.footer {
  padding: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #B8B8B8;
  width: 100%;
}